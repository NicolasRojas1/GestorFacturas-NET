@model AppFacturas.Models.Luz

@{
    ViewData["Title"] = "Registro de Luz";
}

<div class="container mt-5">
    <div class="card shadow-lg border-warning">
        <div class="card-header bg-warning text-dark">
            <h3 class="mb-0">&#9889 Nuevo Registro: Factura Luz</h3>
        </div>
        <div class="card-body">
            <form asp-action="ProcesarLuz" method="post" class="p-4 border rounded bg-light">
                <h3 class="mb-4">Registro de Luz</h3>

                <div class="row mb-3">
                    <div class="col-md-6">
                        <label class="form-label">Valor total de la Luz ($):</label>
                        <input type="number" step="0.01" asp-for="ValorRecibo" class="form-control" required />
                        <span asp-validation-for="ValorRecibo" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Valor total del Kilowatt ($):</label>
                        <input type="number" step="0.0001" asp-for="ValorKw" class="form-control" required />
                        <span asp-validation-for="ValorKw" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Valor total del Aseo ($):</label>
                        <input type="number" step="0.01" asp-for="ValorAseo" class="form-control" required />
                        <span asp-validation-for="ValorAseo" class="text-danger"></span>
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-6">
                        <label class="form-label">Lectura Inicial Recibo:</label>
                        <input type="number" asp-for="LecturaInicialRecibo" class="form-control" required />
                        <span asp-validation-for="LecturaInicialRecibo" class="text-danger"></span>

                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Lectura Final Recibo:</label>
                        <input type="number" asp-for="LecturaFinalRecibo" class="form-control" required />
                        <span asp-validation-for="LecturaFinalRecibo" class="text-danger"></span>
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-6">
                        <label class="form-label">Consumo Inicial Contador:</label>
                        <input type="number" asp-for="ConsumoInicial" class="form-control" required />
                        <span asp-validation-for="ConsumoInicial" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Consumo Final Contador:</label>
                        <input type="number" asp-for="ConsumoFinal" class="form-control" required />
                        <span asp-validation-for="ConsumoFinal" class="text-danger"></span>
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-6">
                        <label class="form-label">Fecha Inicio Periodo:</label>
                        <input type="date" asp-for="FechaInicial" class="form-control" required />
                        <span asp-validation-for="FechaInicial" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Fecha Fin Periodo:</label>
                        <input type="date" asp-for="FechaFinal" class="form-control" required />
                        <span asp-validation-for="FechaFinal" class="text-danger"></span>
                    </div>
                </div>

                <button type="submit" class="btn btn-primary w-100">
                    <i class="bi bi-calculator"></i> Procesar Cálculos
                </button>
            </form>
        </div>
    </div>
</div>

