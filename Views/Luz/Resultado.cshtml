@model AppFacturas.Models.Luz;

@{
    // Extraemos todos los cálculos una sola vez
    var (c1, c2) = Model.CalcularConsumos();
    var (p1, p2) = Model.CalcularPorcentajes();
    var (l1, l2, aseoIndiv, total1, total2, totalLuz) = Model.CalcularPagos();
    var total = @Model.ValorRecibo;
}

<div class="container mt-5">
    <div class="card shadow-lg border-0">

        <div class="card-header recibo-luz-header text-center py-4">
            <h2 class="fw-bold mb-0">⚡ REPORTE DE ENERGÍA</h2>
            <small class="text-uppercase fw-bold opacity-75">Cobro de servicios compartidos</small>
        </div>

        <div class="card-body p-4">
            <div class="row align-items-center">
                <div class="col-md-7">
                    <h5 class="text-secondary border-bottom pb-2">Información del Periodo</h5>
                    <div class="row mt-3">
                        <div class="col-6 text-muted">Desde / Hasta:</div>
                        <div class="col-6 fw-bold">@Model.FechaInicial.ToShortDateString() - @Model.FechaFinal.ToShortDateString()</div>

                        <div class="col-6 text-muted">Valor Total Luz:</div>
                        <div class="col-6 fw-bold">@totalLuz.ToString("C0")</div>

                        <div class="col-6 text-muted">Costo Aseo (Total):</div>
                        <div class="col-6 fw-bold">@Model.ValorAseo.ToString("C0")</div>

                        <div class="col-6 text-muted">Total Recibo:</div>
                        <div class="col-6 fw-bold text-success">@total.ToString("C0")</div>
                    </div>
                </div>
                <div class="col-md-5 text-center border-start">
                    <span class="badge bg-warning text-dark mb-2">CONSUMO TOTAL DETECTADO</span>
                    <h1 class="display-3 fw-bold recibo-consumo-display">@Model.ConsumoTotal<small class="h4"> kWh</small></h1>
                </div>
            </div>

            <hr class="my-4" />

            <div class="row g-4">
                <div class="col-md-6">
                    <div class="card border-0 bg-light shadow-sm h-100">
                        <div class="card-body p-4">
                            <h4 class="recibo-luz-titulo">Apartamento 2</h4>

                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-muted">Consumo (@p1.ToString("F1")%):</span>
                                <span class="fw-bold">@c1 kWh</span>
                            </div>
                            <div class="d-flex justify-content-between small text-muted mb-1">
                                <span>Valor Energía:</span>
                                <span>@l1.ToString("C0")</span>
                            </div>
                            <div class="d-flex justify-content-between small text-muted mb-3">
                                <span>Cuota Aseo:</span>
                                <span>@aseoIndiv.ToString("C0")</span>
                            </div>

                            <div class="d-flex justify-content-between align-items-center recibo-total-box">
                                <span class="h5 mb-0 fw-bold">TOTAL</span>
                                <span class="h3 mb-0 fw-bolder text-dark">@total1.ToString("C0")</span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="card border-0 bg-light shadow-sm h-100">
                        <div class="card-body p-4">
                            <h4 class="recibo-luz-titulo">Apartamento 1</h4>

                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-muted">Consumo (@p2.ToString("F1")%):</span>
                                <span class="fw-bold">@c2 kWh</span>
                            </div>
                            <div class="d-flex justify-content-between small text-muted mb-1">
                                <span>Valor Energía:</span>
                                <span>@l2.ToString("C0")</span>
                            </div>
                            <div class="d-flex justify-content-between small text-muted mb-3">
                                <span>Cuota Aseo:</span>
                                <span>@aseoIndiv.ToString("C0")</span>
                            </div>

                            <div class="d-flex justify-content-between align-items-center recibo-total-box">
                                <span class="h5 mb-0 fw-bold">TOTAL</span>
                                <span class="h3 mb-0 fw-bolder text-dark">@total2.ToString("C0")</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card-footer bg-white border-0 text-center pb-4">
            <a asp-controller="Luz" asp-action="Registro" class="btn btn-outline-secondary px-4 me-2">
                Regresar
            </a>
            <button class="btn btn-warning fw-bold px-4" onclick="window.print()">
                Imprimir PDF
            </button>
        </div>
    </div>
</div>